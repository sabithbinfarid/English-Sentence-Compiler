Grammar

    0 $accept: source $end

    1 source: PROGRAM IDENTIFIER NEWLINE define_list stmt_list END_PROGRAM
    2       | PROGRAM IDENTIFIER NEWLINE define_list stmt_list END_PROGRAM NEWLINE

    3 define_list: /* empty */
    4            | define_list define_stmt

    5 $@1: /* empty */

    6 $@2: /* empty */

    7 define_stmt: DEFINE IDENTIFIER LPAREN $@1 param_list_opt RPAREN NEWLINE $@2 stmt_list END_DEFINE NEWLINE

    8 param_list_opt: /* empty */
    9               | param_list

   10 param_list: param
   11           | param_list COMMA param

   12 param: type_spec IDENTIFIER

   13 stmt_list: /* empty */
   14          | stmt_list statement

   15 statement: NEWLINE
   16          | set_stmt NEWLINE
   17          | say_stmt NEWLINE
   18          | give_stmt NEWLINE
   19          | call_stmt NEWLINE
   20          | when_stmt
   21          | repeat_stmt
   22          | while_stmt

   23 set_stmt: SET type_spec IDENTIFIER TO expr
   24         | SET IDENTIFIER TO expr

   25 say_stmt: SAY expr

   26 $@3: /* empty */

   27 when_stmt: WHEN condition NEWLINE $@3 stmt_list else_opt END_WHEN

   28 else_opt: /* empty */

   29 $@4: /* empty */

   30 else_opt: OTHERWISE NEWLINE $@4 stmt_list

   31 $@5: /* empty */

   32 repeat_stmt: REPEAT expr TIMES NEWLINE $@5 stmt_list END_REPEAT

   33 $@6: /* empty */

   34 while_stmt: WHILE condition NEWLINE $@6 stmt_list END_WHILE

   35 give_stmt: GIVE expr

   36 call_stmt: call_expr

   37 call_expr: CALL IDENTIFIER LPAREN arg_list_opt RPAREN

   38 arg_list_opt: /* empty */
   39             | arg_list

   40 arg_list: expr
   41         | arg_list COMMA expr

   42 type_spec: NUM
   43          | DECIMAL
   44          | TEXT

   45 condition: cond_or

   46 cond_or: cond_or OR cond_and
   47        | cond_and

   48 cond_and: cond_and AND cond_not
   49         | cond_not

   50 cond_not: NOT cond_not
   51         | cond_atom

   52 cond_atom: comparison
   53          | LPAREN condition RPAREN

   54 comparison: expr IS GREATER THAN expr
   55           | expr IS LESS THAN expr
   56           | expr IS EQUALS expr

   57 expr: expr PLUS term
   58     | expr MINUS term
   59     | term

   60 term: term STAR factor
   61     | term SLASH factor
   62     | factor

   63 factor: MINUS factor
   64       | primary

   65 primary: INT_LITERAL
   66        | FLOAT_LITERAL
   67        | STRING_LITERAL
   68        | IDENTIFIER
   69        | call_expr
   70        | LPAREN expr RPAREN


